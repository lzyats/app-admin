<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysUserWalletMapper">

    <resultMap type="SysUserWallet" id="SysUserWalletResult">
        <id property="walletId" column="wallet_id" />
        <result property="userId" column="user_id" />
        <result property="currencyType" column="currency_type" />
        <result property="userName" column="user_name" />
        <result property="totalInvest" column="total_invest" />
        <result property="availableBalance" column="available_balance" />
        <result property="usdExchangeQuota" column="usd_exchange_quota" />
        <result property="frozenAmount" column="frozen_amount" />
        <result property="profitAmount" column="profit_amount" />
        <result property="pendingAmount" column="pending_amount" />
        <result property="totalRecharge" column="total_recharge" />
        <result property="totalWithdraw" column="total_withdraw" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectWalletVo">
        select w.wallet_id, w.user_id, w.currency_type, u.user_name, w.total_invest, w.available_balance, w.usd_exchange_quota, w.frozen_amount,
               w.profit_amount, w.pending_amount, w.total_recharge, w.total_withdraw,
               w.create_time, w.update_time
        from sys_user_wallet w
        left join sys_user u on w.user_id = u.user_id
    </sql>

    <select id="selectWalletByUserId" parameterType="Long" resultMap="SysUserWalletResult">
        <include refid="selectWalletVo" />
        where w.user_id = #{userId}
        order by case when w.currency_type = 'CNY' then 0 when w.currency_type = 'USD' then 1 else 9 end, w.wallet_id asc
        limit 1
    </select>

    <select id="selectWalletByUserIdAndCurrencyType" resultMap="SysUserWalletResult">
        <include refid="selectWalletVo" />
        where w.user_id = #{userId}
          and w.currency_type = #{currencyType}
        limit 1
    </select>

    <select id="selectWalletByUserIdAndCurrencyTypeForUpdate" resultMap="SysUserWalletResult">
        <include refid="selectWalletVo" />
        where w.user_id = #{userId}
          and w.currency_type = #{currencyType}
        limit 1
        for update
    </select>

    <select id="selectWalletById" parameterType="Long" resultMap="SysUserWalletResult">
        <include refid="selectWalletVo" />
        where w.wallet_id = #{walletId}
    </select>

    <select id="selectWalletList" parameterType="SysUserWallet" resultMap="SysUserWalletResult">
        <include refid="selectWalletVo" />
        <where>
            <if test="userId != null">
                and w.user_id = #{userId}
            </if>
            <if test="currencyType != null and currencyType != ''">
                and w.currency_type = #{currencyType}
            </if>
            <if test="totalInvest != null">
                and w.total_invest = #{totalInvest}
            </if>
            <if test="availableBalance != null">
                and w.available_balance = #{availableBalance}
            </if>
            <if test="usdExchangeQuota != null">
                and w.usd_exchange_quota = #{usdExchangeQuota}
            </if>
            <if test="frozenAmount != null">
                and w.frozen_amount = #{frozenAmount}
            </if>
            <if test="profitAmount != null">
                and w.profit_amount = #{profitAmount}
            </if>
            <if test="pendingAmount != null">
                and w.pending_amount = #{pendingAmount}
            </if>
        </where>
    </select>

    <insert id="insertWallet" parameterType="SysUserWallet">
        insert into sys_user_wallet
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="currencyType != null and currencyType != ''">currency_type,</if>
            <if test="totalInvest != null">total_invest,</if>
            <if test="availableBalance != null">available_balance,</if>
            <if test="usdExchangeQuota != null">usd_exchange_quota,</if>
            <if test="frozenAmount != null">frozen_amount,</if>
            <if test="profitAmount != null">profit_amount,</if>
            <if test="pendingAmount != null">pending_amount,</if>
            <if test="totalRecharge != null">total_recharge,</if>
            <if test="totalWithdraw != null">total_withdraw,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="currencyType != null and currencyType != ''">#{currencyType},</if>
            <if test="totalInvest != null">#{totalInvest},</if>
            <if test="availableBalance != null">#{availableBalance},</if>
            <if test="usdExchangeQuota != null">#{usdExchangeQuota},</if>
            <if test="frozenAmount != null">#{frozenAmount},</if>
            <if test="profitAmount != null">#{profitAmount},</if>
            <if test="pendingAmount != null">#{pendingAmount},</if>
            <if test="totalRecharge != null">#{totalRecharge},</if>
            <if test="totalWithdraw != null">#{totalWithdraw},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateWallet" parameterType="SysUserWallet">
        update sys_user_wallet
        <set>
            <if test="currencyType != null and currencyType != ''">currency_type = #{currencyType},</if>
            <if test="totalInvest != null">total_invest = #{totalInvest},</if>
            <if test="availableBalance != null">available_balance = #{availableBalance},</if>
            <if test="usdExchangeQuota != null">usd_exchange_quota = #{usdExchangeQuota},</if>
            <if test="frozenAmount != null">frozen_amount = #{frozenAmount},</if>
            <if test="profitAmount != null">profit_amount = #{profitAmount},</if>
            <if test="pendingAmount != null">pending_amount = #{pendingAmount},</if>
            <if test="totalRecharge != null">total_recharge = #{totalRecharge},</if>
            <if test="totalWithdraw != null">total_withdraw = #{totalWithdraw},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where wallet_id = #{walletId}
    </update>

    <delete id="deleteWalletById" parameterType="Long">
        delete from sys_user_wallet where wallet_id = #{walletId}
    </delete>

    <delete id="deleteWalletByIds" parameterType="Long[]">
        delete from sys_user_wallet where wallet_id in
        <foreach item="walletId" collection="array" open="(" separator="," close=")">
            #{walletId}
        </foreach>
    </delete>

</mapper>
