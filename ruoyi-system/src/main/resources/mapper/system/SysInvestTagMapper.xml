<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysInvestTagMapper">

    <resultMap type="SysInvestTag" id="SysInvestTagResult">
        <id property="tagId" column="tag_id"/>
        <result property="tagCode" column="tag_code"/>
        <result property="tagName" column="tag_name"/>
        <result property="tagColor" column="tag_color"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectInvestTagVo">
        select tag_id, tag_code, tag_name, tag_color, sort_order, status, create_by, create_time, update_by, update_time, remark
        from sys_invest_tag
    </sql>

    <select id="selectInvestTagById" parameterType="Long" resultMap="SysInvestTagResult">
        <include refid="selectInvestTagVo"/>
        where tag_id = #{tagId}
    </select>

    <select id="selectInvestTagList" parameterType="SysInvestTag" resultMap="SysInvestTagResult">
        <include refid="selectInvestTagVo"/>
        <where>
            <if test="tagCode != null and tagCode != ''">and tag_code like concat('%', #{tagCode}, '%')</if>
            <if test="tagName != null and tagName != ''">and tag_name like concat('%', #{tagName}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by sort_order asc, tag_id desc
    </select>

    <insert id="insertInvestTag" parameterType="SysInvestTag" useGeneratedKeys="true" keyProperty="tagId">
        insert into sys_invest_tag(tag_code, tag_name, tag_color, sort_order, status, create_by, create_time, remark)
        values (#{tagCode}, #{tagName}, #{tagColor}, #{sortOrder}, #{status}, #{createBy}, now(), #{remark})
    </insert>

    <update id="updateInvestTag" parameterType="SysInvestTag">
        update sys_invest_tag
        <trim prefix="set" suffixOverrides=",">
            <if test="tagCode != null and tagCode != ''">tag_code = #{tagCode},</if>
            <if test="tagName != null and tagName != ''">tag_name = #{tagName},</if>
            <if test="tagColor != null and tagColor != ''">tag_color = #{tagColor},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_by = #{updateBy},
            update_time = now()
        </trim>
        where tag_id = #{tagId}
    </update>

    <delete id="deleteInvestTagById" parameterType="Long">
        delete from sys_invest_tag where tag_id = #{tagId}
    </delete>

    <delete id="deleteInvestTagByIds" parameterType="Long">
        delete from sys_invest_tag where tag_id in
        <foreach collection="array" item="tagId" open="(" separator="," close=")">
            #{tagId}
        </foreach>
    </delete>
</mapper>
