<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysNewsArticleMapper">

    <resultMap type="SysNewsArticle" id="SysNewsArticleResult">
        <id property="articleId" column="article_id" />
        <result property="categoryId" column="category_id" />
        <result property="categoryCode" column="category_code" />
        <result property="categoryName" column="category_name" />
        <result property="articleTitle" column="article_title" />
        <result property="summary" column="summary" />
        <result property="coverImage" column="cover_image" />
        <result property="articleContent" column="article_content" />
        <result property="sortOrder" column="sort_order" />
        <result property="topFlag" column="top_flag" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectNewsArticleVo">
        select a.article_id,
               a.category_id,
               a.category_code,
               c.category_name,
               a.article_title,
               a.summary,
               a.cover_image,
               a.article_content,
               a.sort_order,
               a.top_flag,
               a.status,
               a.create_time,
               a.update_time,
               a.remark
        from sys_news_article a
        left join sys_news_category c on c.category_id = a.category_id
    </sql>

    <select id="selectNewsArticleList" parameterType="SysNewsArticle" resultMap="SysNewsArticleResult">
        <include refid="selectNewsArticleVo"/>
        <where>
            <if test="articleTitle != null and articleTitle != ''">
                and a.article_title like concat('%', #{articleTitle}, '%')
            </if>
            <if test="categoryId != null">
                and a.category_id = #{categoryId}
            </if>
            <if test="categoryCode != null and categoryCode != ''">
                and a.category_code = #{categoryCode}
            </if>
            <if test="status != null and status != ''">
                and a.status = #{status}
            </if>
        </where>
        order by a.top_flag desc, a.sort_order asc, a.article_id desc
    </select>

    <select id="selectNewsArticleAll" parameterType="SysNewsArticle" resultMap="SysNewsArticleResult">
        <include refid="selectNewsArticleVo"/>
        <where>
            <if test="articleTitle != null and articleTitle != ''">
                and a.article_title like concat('%', #{articleTitle}, '%')
            </if>
            <if test="categoryCode != null and categoryCode != ''">
                and a.category_code = #{categoryCode}
            </if>
            <if test="status != null and status != ''">
                and a.status = #{status}
            </if>
        </where>
        order by a.top_flag desc, a.sort_order asc, a.article_id desc
    </select>

    <select id="selectNewsArticleById" parameterType="Long" resultMap="SysNewsArticleResult">
        <include refid="selectNewsArticleVo"/>
        where a.article_id = #{articleId}
    </select>

    <insert id="insertNewsArticle" parameterType="SysNewsArticle" useGeneratedKeys="true" keyProperty="articleId">
        insert into sys_news_article (
            <if test="categoryId != null">category_id,</if>
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="articleTitle != null and articleTitle != ''">article_title,</if>
            <if test="summary != null and summary != ''">summary,</if>
            <if test="coverImage != null and coverImage != ''">cover_image,</if>
            <if test="articleContent != null and articleContent != ''">article_content,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="topFlag != null and topFlag != ''">top_flag,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_by, create_time
        ) values (
            <if test="categoryId != null">#{categoryId},</if>
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="articleTitle != null and articleTitle != ''">#{articleTitle},</if>
            <if test="summary != null and summary != ''">#{summary},</if>
            <if test="coverImage != null and coverImage != ''">#{coverImage},</if>
            <if test="articleContent != null and articleContent != ''">#{articleContent},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="topFlag != null and topFlag != ''">#{topFlag},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            #{createBy}, now()
        )
    </insert>

    <update id="updateNewsArticle" parameterType="SysNewsArticle">
        update sys_news_article
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="articleTitle != null and articleTitle != ''">article_title = #{articleTitle},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="articleContent != null">article_content = #{articleContent},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="topFlag != null and topFlag != ''">top_flag = #{topFlag},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_by = #{updateBy},
            update_time = now()
        </set>
        where article_id = #{articleId}
    </update>

    <delete id="deleteNewsArticleById" parameterType="Long">
        delete from sys_news_article where article_id = #{articleId}
    </delete>

    <delete id="deleteNewsArticleByIds" parameterType="Long">
        delete from sys_news_article where article_id in
        <foreach item="articleId" collection="array" open="(" separator="," close=")">
            #{articleId}
        </foreach>
    </delete>
</mapper>
