<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysUserLevelMapper">

    <resultMap type="SysUserLevel" id="SysUserLevelResult">
        <id     property="levelId"               column="level_id" />
        <result property="level"                 column="level" />
        <result property="levelName"             column="level_name" />
        <result property="requiredGrowthValue"  column="required_growth_value" />
        <result property="investBonus"           column="invest_bonus" />
        <result property="icon"                  column="icon" />
        <result property="status"                column="status" />
        <result property="createBy"              column="create_by" />
        <result property="createTime"            column="create_time" />
        <result property="updateBy"              column="update_by" />
        <result property="updateTime"            column="update_time" />
        <result property="remark"                column="remark" />
    </resultMap>

    <sql id="selectUserLevelVo">
        select level_id, level, level_name, required_growth_value, invest_bonus, icon,
               status, create_by, create_time, update_by, update_time, remark
        from sys_user_level
    </sql>

    <select id="selectUserLevelById" parameterType="Long" resultMap="SysUserLevelResult">
        <include refid="selectUserLevelVo"/>
        where level_id = #{levelId}
    </select>

    <select id="selectUserLevelList" parameterType="SysUserLevel" resultMap="SysUserLevelResult">
        <include refid="selectUserLevelVo"/>
        <where>
            <if test="level != null">and level = #{level}</if>
            <if test="levelName != null and levelName != ''">and level_name like concat('%', #{levelName}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by level asc, level_id desc
    </select>

    <insert id="insertUserLevel" parameterType="SysUserLevel" useGeneratedKeys="true" keyProperty="levelId">
        insert into sys_user_level
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="level != null">level,</if>
            <if test="levelName != null">level_name,</if>
            <if test="requiredGrowthValue != null">required_growth_value,</if>
            <if test="investBonus != null">invest_bonus,</if>
            <if test="icon != null">icon,</if>
            <if test="status != null">status,</if>
            create_by,
            create_time,
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="level != null">#{level},</if>
            <if test="levelName != null">#{levelName},</if>
            <if test="requiredGrowthValue != null">#{requiredGrowthValue},</if>
            <if test="investBonus != null">#{investBonus},</if>
            <if test="icon != null">#{icon},</if>
            <if test="status != null">#{status},</if>
            #{createBy},
            now(),
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateUserLevel" parameterType="SysUserLevel">
        update sys_user_level
        <trim prefix="SET" suffixOverrides=",">
            <if test="level != null">level = #{level},</if>
            <if test="levelName != null">level_name = #{levelName},</if>
            <if test="requiredGrowthValue != null">required_growth_value = #{requiredGrowthValue},</if>
            <if test="investBonus != null">invest_bonus = #{investBonus},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="status != null">status = #{status},</if>
            update_by = #{updateBy},
            update_time = now(),
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where level_id = #{levelId}
    </update>

    <delete id="deleteUserLevelById" parameterType="Long">
        delete from sys_user_level where level_id = #{levelId}
    </delete>

    <delete id="deleteUserLevelByIds" parameterType="Long">
        delete from sys_user_level where level_id in
        <foreach collection="array" item="levelId" open="(" separator="," close=")">
            #{levelId}
        </foreach>
    </delete>

</mapper>
