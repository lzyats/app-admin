<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysYebaoIncomeLogMapper">

    <resultMap type="SysYebaoIncomeLog" id="SysYebaoIncomeLogResult">
        <id property="incomeId" column="income_id" />
        <result property="incomeNo" column="income_no" />
        <result property="orderId" column="order_id" />
        <result property="orderNo" column="order_no" />
        <result property="userId" column="user_id" />
        <result property="userName" column="user_name" />
        <result property="shares" column="shares" />
        <result property="principalAmount" column="principal_amount" />
        <result property="annualRate" column="annual_rate" />
        <result property="settleDays" column="settle_days" />
        <result property="incomeAmount" column="income_amount" />
        <result property="periodStartTime" column="period_start_time" />
        <result property="periodEndTime" column="period_end_time" />
        <result property="settleTime" column="settle_time" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectYebaoIncomeVo">
        select income_id, income_no, order_id, order_no, user_id, user_name, shares, principal_amount, annual_rate,
               settle_days, income_amount, period_start_time, period_end_time, settle_time, status, create_by,
               create_time, update_by, update_time, remark
        from sys_yebao_income_log
    </sql>

    <select id="selectYebaoIncomeLogList" parameterType="SysYebaoIncomeLog" resultMap="SysYebaoIncomeLogResult">
        <include refid="selectYebaoIncomeVo" />
        <where>
            <if test="incomeNo != null and incomeNo != ''">
                and income_no like concat('%', #{incomeNo}, '%')
            </if>
            <if test="orderNo != null and orderNo != ''">
                and order_no like concat('%', #{orderNo}, '%')
            </if>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="userName != null and userName != ''">
                and user_name like concat('%', #{userName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="settleTime != null">
                and settle_time >= #{settleTime}
            </if>
        </where>
        order by settle_time desc, income_id desc
    </select>

    <select id="selectAppYebaoIncomeLogList" parameterType="Long" resultMap="SysYebaoIncomeLogResult">
        <include refid="selectYebaoIncomeVo" />
        where user_id = #{userId}
        order by settle_time desc, income_id desc
        limit 10
    </select>

    <select id="selectYebaoIncomeLogById" parameterType="Long" resultMap="SysYebaoIncomeLogResult">
        <include refid="selectYebaoIncomeVo" />
        where income_id = #{incomeId}
    </select>

    <insert id="insertYebaoIncomeLog" parameterType="SysYebaoIncomeLog" useGeneratedKeys="true" keyProperty="incomeId">
        insert into sys_yebao_income_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="incomeNo != null and incomeNo != ''">income_no,</if>
            <if test="orderId != null">order_id,</if>
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="userId != null">user_id,</if>
            <if test="userName != null and userName != ''">user_name,</if>
            <if test="shares != null">shares,</if>
            <if test="principalAmount != null">principal_amount,</if>
            <if test="annualRate != null">annual_rate,</if>
            <if test="settleDays != null">settle_days,</if>
            <if test="incomeAmount != null">income_amount,</if>
            <if test="periodStartTime != null">period_start_time,</if>
            <if test="periodEndTime != null">period_end_time,</if>
            <if test="settleTime != null">settle_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="incomeNo != null and incomeNo != ''">#{incomeNo},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="userId != null">#{userId},</if>
            <if test="userName != null and userName != ''">#{userName},</if>
            <if test="shares != null">#{shares},</if>
            <if test="principalAmount != null">#{principalAmount},</if>
            <if test="annualRate != null">#{annualRate},</if>
            <if test="settleDays != null">#{settleDays},</if>
            <if test="incomeAmount != null">#{incomeAmount},</if>
            <if test="periodStartTime != null">#{periodStartTime},</if>
            <if test="periodEndTime != null">#{periodEndTime},</if>
            <if test="settleTime != null">#{settleTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateYebaoIncomeLog" parameterType="SysYebaoIncomeLog">
        update sys_yebao_income_log
        <set>
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="userName != null and userName != ''">user_name = #{userName},</if>
            <if test="shares != null">shares = #{shares},</if>
            <if test="principalAmount != null">principal_amount = #{principalAmount},</if>
            <if test="annualRate != null">annual_rate = #{annualRate},</if>
            <if test="settleDays != null">settle_days = #{settleDays},</if>
            <if test="incomeAmount != null">income_amount = #{incomeAmount},</if>
            <if test="periodStartTime != null">period_start_time = #{periodStartTime},</if>
            <if test="periodEndTime != null">period_end_time = #{periodEndTime},</if>
            <if test="settleTime != null">settle_time = #{settleTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where income_id = #{incomeId}
    </update>

    <delete id="deleteYebaoIncomeLogById" parameterType="Long">
        delete from sys_yebao_income_log where income_id = #{incomeId}
    </delete>

    <delete id="deleteYebaoIncomeLogByIds" parameterType="Long[]">
        delete from sys_yebao_income_log where income_id in
        <foreach item="incomeId" collection="array" open="(" separator="," close=")">
            #{incomeId}
        </foreach>
    </delete>
</mapper>
