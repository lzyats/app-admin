<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysAppRealNameAuthMapper">

    <resultMap type="SysAppRealNameAuth" id="SysAppRealNameAuthResult">
        <id     property="authId"           column="auth_id"          />
        <result property="userId"            column="user_id"          />
        <result property="userName"         column="user_name"        />
        <result property="realName"          column="real_name"        />
        <result property="idCardNumber"      column="id_card_number"   />
        <result property="idCardFront"       column="id_card_front"    />
        <result property="idCardBack"        column="id_card_back"     />
        <result property="handheldPhoto"     column="handheld_photo"   />
        <result property="status"            column="status"           />
        <result property="rejectReason"      column="reject_reason"   />
        <result property="submitTime"        column="submit_time"      />
        <result property="reviewTime"        column="review_time"      />
        <result property="reviewUserId"       column="review_user_id"    />
        <result property="reviewUserName"     column="review_user_name"  />
        <result property="createTime"        column="create_time"      />
        <result property="updateTime"        column="update_time"      />
        <result property="remark"            column="remark"           />
    </resultMap>

    <sql id="selectAuthVo">
        select auth_id, user_id, user_name, real_name, id_card_number,
               id_card_front, id_card_back, handheld_photo, status,
               reject_reason, submit_time, review_time, review_user_id,
               review_user_name, create_time, update_time, remark
        from sys_app_real_name_auth
    </sql>

    <select id="selectAuthList" parameterType="SysAppRealNameAuth" resultMap="SysAppRealNameAuthResult">
        <include refid="selectAuthVo"/>
        <where>
            <if test="userId != null">
                AND user_id = #{userId}
            </if>
            <if test="userName != null and userName != ''">
                AND user_name like concat('%', #{userName}, '%')
            </if>
            <if test="realName != null and realName != ''">
                AND real_name like concat('%', #{realName}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        order by submit_time desc
    </select>

    <select id="selectAuthByUserId" parameterType="Long" resultMap="SysAppRealNameAuthResult">
        <include refid="selectAuthVo"/>
        where user_id = #{userId}
        order by submit_time desc
        limit 1
    </select>

    <select id="selectAuthById" parameterType="Long" resultMap="SysAppRealNameAuthResult">
        <include refid="selectAuthVo"/>
        where auth_id = #{authId}
    </select>

    <insert id="insertAuth" parameterType="SysAppRealNameAuth">
        insert into sys_app_real_name_auth (
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="realName != null and realName != ''">real_name,</if>
            <if test="idCardNumber != null and idCardNumber != ''">id_card_number,</if>
            <if test="idCardFront != null and idCardFront != ''">id_card_front,</if>
            <if test="idCardBack != null and idCardBack != ''">id_card_back,</if>
            <if test="handheldPhoto != null and handheldPhoto != ''">handheld_photo,</if>
            <if test="status != null">status,</if>
            <if test="submitTime != null">submit_time,</if>
            <if test="remark != null">remark,</if>
            create_time
        )values(
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="realName != null and realName != ''">#{realName},</if>
            <if test="idCardNumber != null and idCardNumber != ''">#{idCardNumber},</if>
            <if test="idCardFront != null and idCardFront != ''">#{idCardFront},</if>
            <if test="idCardBack != null and idCardBack != ''">#{idCardBack},</if>
            <if test="handheldPhoto != null and handheldPhoto != ''">#{handheldPhoto},</if>
            <if test="status != null">#{status},</if>
            <if test="submitTime != null">#{submitTime},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateAuth" parameterType="SysAppRealNameAuth">
        update sys_app_real_name_auth
        <set>
            <if test="status != null">status = #{status},</if>
            <if test="rejectReason != null">reject_reason = #{rejectReason},</if>
            <if test="reviewTime != null">review_time = #{reviewTime},</if>
            <if test="reviewUserId != null">review_user_id = #{reviewUserId},</if>
            <if test="reviewUserName != null">review_user_name = #{reviewUserName},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where auth_id = #{authId}
    </update>

    <delete id="deleteAuthById" parameterType="Long">
        delete from sys_app_real_name_auth where auth_id = #{authId}
    </delete>

    <delete id="deleteAuthByIds" parameterType="Long">
        delete from sys_app_real_name_auth where auth_id in
        <foreach item="authId" collection="array" open="(" separator="," close=")">
            #{authId}
        </foreach>
    </delete>

</mapper>